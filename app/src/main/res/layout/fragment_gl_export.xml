<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <TextView
        android:id="@+id/video_plus_filter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="视频加滤镜输出"
        android:textSize="20dp"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/video_plus_audio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="视频加音频输出"
        android:textSize="20dp"
        app:layout_constraintTop_toBottomOf="@id/video_plus_filter" />

    <TextView
        android:id="@+id/video_plus_filter_effect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="原视频加水印加特效加音频混合输出"
        android:textSize="20dp"
        app:layout_constraintTop_toBottomOf="@id/video_plus_audio" />


    <TextView
        android:id="@+id/video_effect1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="特效一"
        android:textSize="20dp"
        android:layout_marginTop="60dp"
        app:layout_constraintTop_toBottomOf="@id/video_plus_filter_effect"/>

    <TextView
        android:id="@+id/video_effect3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="特效三"
        android:textSize="20dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/video_effect1"/>

    <TextView
        android:id="@+id/video_effect4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="特效四"
        android:textSize="20dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/video_effect3"/>


</androidx.constraintlayout.widget.ConstraintLayout>
